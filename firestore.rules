rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
        request.auth.token.role == role;
    }
    
    function isValidHealthSystem(healthSystem) {
      return healthSystem in ['default', 'system1', 'system2', 'system3'];
    }
    
    function isValidPopulationType(popType) {
      return popType in ['Neonatal', 'Pediatric', 'Adolescent', 'Adult'];
    }
    
    // Rate limiting helper (basic implementation)
    function rateLimitCheck() {
      // In production, implement proper rate limiting
      return true;
    }
    
    // Validate medical data ranges
    function isValidMedicalValue(value) {
      return value is number && value >= 0 && value <= 10000;
    }
    
    // Validate TPN calculation data
    function isValidTPNData(data) {
      return data.keys().hasAll(['name', 'content', 'version']) &&
        data.name is string && data.name.size() <= 500 &&
        data.content is string && data.content.size() <= 50000 &&
        data.version is number && data.version >= 0;
    }
    
    // References collection - TPN calculation references
    match /references/{referenceId} {
      // Allow read for authenticated users
      allow read: if isAuthenticated() && rateLimitCheck();
      
      // Allow create with validation
      allow create: if isAuthenticated() && 
        isValidTPNData(request.resource.data) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        rateLimitCheck();
      
      // Allow update only by owner with version increment
      allow update: if isOwner(resource.data.userId) &&
        isValidTPNData(request.resource.data) &&
        request.resource.data.version == resource.data.version + 1 &&
        request.resource.data.modifiedAt == request.time &&
        rateLimitCheck();
      
      // Allow delete only by owner or admin
      allow delete: if isOwner(resource.data.userId) || hasRole('admin');
    }
    
    // Configs collection - TPN configuration data
    match /configs/{configId} {
      // Allow read for authenticated users
      allow read: if isAuthenticated() && rateLimitCheck();
      
      // Allow create with validation
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['name', 'healthSystem', 'populationType']) &&
        isValidHealthSystem(request.resource.data.healthSystem) &&
        isValidPopulationType(request.resource.data.populationType) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        rateLimitCheck();
      
      // Allow update only by creator or admin
      allow update: if (isOwner(resource.data.createdBy) || hasRole('admin')) &&
        isValidHealthSystem(request.resource.data.healthSystem) &&
        isValidPopulationType(request.resource.data.populationType) &&
        request.resource.data.modifiedAt == request.time &&
        rateLimitCheck();
      
      // Allow delete only by creator or admin
      allow delete: if isOwner(resource.data.createdBy) || hasRole('admin');
    }
    
    // Ingredients collection - Medical ingredient data
    match /ingredients/{healthSystem}/populationTypes/{populationType}/ingredients/{ingredientId} {
      // Validate health system and population type in path
      allow read: if isAuthenticated() && 
        isValidHealthSystem(healthSystem) &&
        isValidPopulationType(populationType) &&
        rateLimitCheck();
      
      // Allow create with medical data validation
      allow create: if isAuthenticated() &&
        isValidHealthSystem(healthSystem) &&
        isValidPopulationType(populationType) &&
        request.resource.data.keys().hasAll(['name', 'content', 'version']) &&
        request.resource.data.name is string &&
        request.resource.data.content is string &&
        request.resource.data.version == 1 &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        rateLimitCheck();
      
      // Allow update with version control
      allow update: if isAuthenticated() &&
        request.resource.data.version == resource.data.version + 1 &&
        request.resource.data.modifiedBy == request.auth.uid &&
        request.resource.data.modifiedAt == request.time &&
        rateLimitCheck();
      
      // Restrict delete to admins only (medical data protection)
      allow delete: if hasRole('admin');
    }
    
    // Baseline configs - Immutable reference data
    match /baselineConfigs/{configId} {
      // Read-only for all authenticated users
      allow read: if isAuthenticated() && rateLimitCheck();
      
      // Only admins can create baseline configs
      allow create: if hasRole('admin') &&
        request.resource.data.keys().hasAll(['name', 'content', 'version']) &&
        request.resource.data.isBaseline == true;
      
      // Baseline configs are immutable - no updates allowed
      allow update: if false;
      
      // Only admins can delete baseline configs
      allow delete: if hasRole('admin');
    }
    
    // Shared ingredients - Cross-reference ingredient data
    match /sharedIngredients/{sharedId} {
      // Allow read for authenticated users
      allow read: if isAuthenticated() && rateLimitCheck();
      
      // Allow create with reference validation
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['contentHash', 'references']) &&
        request.resource.data.contentHash is string &&
        request.resource.data.references is list &&
        request.resource.data.createdBy == request.auth.uid &&
        rateLimitCheck();
      
      // Allow update to add/remove references
      allow update: if isAuthenticated() &&
        request.resource.data.references is list &&
        request.resource.data.modifiedBy == request.auth.uid &&
        rateLimitCheck();
      
      // Only allow delete if no references remain
      allow delete: if isAuthenticated() &&
        resource.data.references.size() == 0;
    }
    
    // Audit logs - Write-only for compliance
    match /auditLogs/{logId} {
      // No read access except for admins
      allow read: if hasRole('admin');
      
      // Allow authenticated users to write audit logs
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['action', 'timestamp', 'userId']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.timestamp == request.time;
      
      // Audit logs are immutable
      allow update: if false;
      allow delete: if false;
    }
    
    // User preferences and settings
    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId);
      
      // Users can create their own profile
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['email', 'createdAt']) &&
        request.resource.data.createdAt == request.time;
      
      // Users can update their own profile
      allow update: if isOwner(userId) &&
        request.resource.data.modifiedAt == request.time;
      
      // Users cannot delete their profile (for audit trail)
      allow delete: if false;
    }
    
    // Health system configurations (admin only)
    match /healthSystems/{systemId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      
      // Only admins can modify
      allow create, update: if hasRole('admin');
      allow delete: if hasRole('admin');
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}